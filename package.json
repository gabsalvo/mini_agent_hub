{
  "name": "mini-agent-hub",
  "version": "0.1.0",
  "description": "WAIMAKERS coding challenge — MCP server with approval gateway and audit trail",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/server.js",
    "demo": "powershell -ExecutionPolicy Bypass -File start.ps1",
    "demo:unix": "bash start.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
